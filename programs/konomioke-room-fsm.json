  "site": "konomioke",
  "desc": "Room state machine â€” IDLEâ†’LOBBYâ†’SINGINGâ†’PAUSEDâ†’ENDED",
  "states": [
    "IDLE",
    "LOBBY",
    "SINGING",
    "PAUSED",
    "ENDED"
  ],
  "transitions": [
    {
