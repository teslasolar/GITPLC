{
  "_schema": "gitplc/branches/v1",
  "root": "main",
  "branches": {
    "main": {
      "desc": "Base UDT library — universal primitives + ISA templates",
      "children": ["plc-rockwell", "plc-siemens", "plc-codesys", "plc-konomioke"],
      "auto_inherit": true
    },
    "plc-rockwell": {
      "desc": "Allen-Bradley ControlLogix/CompactLogix vendor extensions",
      "parent": "main",
      "vendor": "rockwell",
      "children": ["plc-rockwell-assway"],
      "extends": ["core/udt", "control/*", "equipment/*", "alarms/*"]
    },
    "plc-siemens": {
      "desc": "Siemens S7-1500/TIA Portal vendor extensions",
      "parent": "main",
      "vendor": "siemens",
      "children": [],
      "extends": ["core/udt", "control/*", "equipment/*", "alarms/*"]
    },
    "plc-codesys": {
      "desc": "CODESYS / IEC 61131-3 vendor extensions",
      "parent": "main",
      "vendor": "codesys",
      "children": [],
      "extends": ["core/udt", "control/*", "equipment/*", "alarms/*"]
    },
    "plc-rockwell-assway": {
      "desc": "Assway demo plant — Rockwell instance with site-specific programs",
      "parent": "plc-rockwell",
      "site": "assway",
      "children": []
    },
    "plc-konomioke": {
      "desc": "Konomioke P2P karaoke — rooms, voices, audio fabric, vagal phonemes as ISA-88 equipment",
      "parent": "main",
      "site": "konomioke",
      "children": [],
      "primes": [2, 3, 5, 7, 11, 13, 17],
      "extends": ["core/udt", "equipment/*", "alarms/*"]
    },
    "plc-wearass": {
      "desc": "Galaxy Watch wearable comms — ADB bridge, biosensors, biomarkers, TWrecks kernel",
      "parent": "main",
      "site": "blossom",
      "children": [],
      "wearers": ["thomas", "teresa"],
      "extends": ["core/udt", "equipment/*", "alarms/*"]
    },
    "plc-survey-auto": {
      "desc": "Survey/Q&A platform automation — scan, answer, optimize, harvest payouts",
      "parent": "main",
      "site": "revenue",
      "children": [],
      "platforms": ["1Q","Prolific","SurveyJunkie","Swagbucks","UserTesting","Respondent","JustAnswer","UserInterviews"],
      "extends": ["equipment/*", "programs/*", "alarms/*"]
    }
  }
}
